{
  "name": "@graphite",
  "private": true,
  "version": "0.2.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "check": "biome check --write .",
    "build:mcp": "pnpm --filter @graphite/mcp-server run build:binary && node scripts/place-mcp-binary.mjs",
    "prepare": "husky"
