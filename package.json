    "autoprefixer": "^10.4.20",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "^5.7.3",
    "vite": "^6.0.7"
