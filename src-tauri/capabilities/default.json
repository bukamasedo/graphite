{
  "identifier": "default",
  "description": "Default capabilities for the main window",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "shell:allow-open",
    "core:menu:default",
    "updater:default",
    "dialog:default",
    "process:allow-restart",
    "core:webview:allow-set-webview-zoom"
  ]
}
